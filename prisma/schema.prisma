// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

enum TransactionType {
  INCOME
  EXPENSE
}

enum PaymentMethod {
  BANK
  CASH
  UPI
  CARD
  OTHER
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

// Mirrors a Supabase auth.users row. id is set to the auth user's id at signup time.
model Profile {
  id        String   @id @db.Uuid
  email     String   @unique
  name      String?
  role      Role     @default(MEMBER)
  createdAt DateTime @default(now()) @map("created_at")

  transactions Transaction[] @relation("TransactionCreator")

  @@map("profiles")
}

model Client {
  id           String   @id @default(uuid()) @db.Uuid
  name         String
  contactEmail String?  @map("contact_email")
  contactPhone String?  @map("contact_phone")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at")

  projects     Project[]
  transactions Transaction[]

  @@map("clients")
}

model Project {
  id        String        @id @default(uuid()) @db.Uuid
  clientId  String?       @map("client_id") @db.Uuid
  client    Client?       @relation(fields: [clientId], references: [id], onDelete: SetNull)
  name      String
  status    ProjectStatus @default(ACTIVE)
  budget    Decimal?      @db.Decimal(12, 2)
  createdAt DateTime      @default(now()) @map("created_at")

  transactions Transaction[]

  @@map("projects")
}

model Category {
  id   String          @id @default(uuid()) @db.Uuid
  name String
  type TransactionType

  transactions Transaction[]

  @@unique([name, type])
  @@map("categories")
}

model Transaction {
  id            String          @id @default(uuid()) @db.Uuid
  type          TransactionType
  amount        Decimal         @db.Decimal(12, 2)
  currency      String          @default("INR")
  date          DateTime        @db.Date
  categoryId    String          @map("category_id") @db.Uuid
  category      Category        @relation(fields: [categoryId], references: [id])
  clientId      String?         @map("client_id") @db.Uuid
  client        Client?         @relation(fields: [clientId], references: [id], onDelete: SetNull)
  projectId     String?         @map("project_id") @db.Uuid
  project       Project?        @relation(fields: [projectId], references: [id], onDelete: SetNull)
  description   String?
  paymentMethod PaymentMethod   @default(OTHER) @map("payment_method")
  attachmentUrl String?         @map("attachment_url")
  createdBy     String          @map("created_by") @db.Uuid
  creator       Profile         @relation("TransactionCreator", fields: [createdBy], references: [id])
  createdAt     DateTime        @default(now()) @map("created_at")

  @@index([date])
  @@index([type])
  @@index([clientId])
  @@index([categoryId])
  @@index([createdBy])
  @@map("transactions")
}
